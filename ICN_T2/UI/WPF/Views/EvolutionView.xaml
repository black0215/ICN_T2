<UserControl x:Class="ICN_T2.UI.WPF.Views.EvolutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:ICN_T2.UI.WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100"
             ClipToBounds="False"
             Background="Transparent"
             TextElement.Foreground="#1F1F1F"
             TextElement.FontFamily="{DynamicResource GmarketSansMedium}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/PuniPuniTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True"
          ClipToBounds="False"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          TextOptions.TextHintingMode="Fixed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30*"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="70*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,90,0,0">
            <Border CornerRadius="24"
                    Tag="ToolPanelBackdropGlass"
                    IsHitTestVisible="False"/>
            <Border Background="#33FFFFFF"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="진화 (Evolution)"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1F1F1F"
                               Margin="0,0,0,16"/>

                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Height="44"
                            Style="{StaticResource IosSearchFieldStyle}">
                        <Grid>
                            <TextBlock Text="Search Yokai..."
                                       FontSize="14"
                                       Foreground="#601F1F1F"
                                       Margin="14,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtYokaiSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="TxtYokaiSearch"
                                     Padding="14,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Foreground="#1F1F1F"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Evolutions}"
                             SelectedItem="{Binding SelectedYokai, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource IosListItemStyle}">
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- Simple Filter for Search -->
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtYokaiSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2"
              Margin="0,-15,0,-30"
              ClipToBounds="False"
              Visibility="{Binding SelectedYokai, Converter={StaticResource NullToVisibility}}">
            <Border CornerRadius="28"
                    Tag="ToolPanelBackdropGlass"
                    IsHitTestVisible="False"/>
            <Border Background="#33FFFFFF"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="28"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0">
                    <StackPanel DataContext="{Binding SelectedYokai}">
                        <Border Background="#40FFFFFF"
                                BorderBrush="#15FFFFFF"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1F1F1F"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Base Yokai"
                                           FontSize="12"
                                           Opacity="0.68"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#40FFFFFF"
                                BorderBrush="#15FFFFFF"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Evolves To..." FontSize="11" FontWeight="Bold" Opacity="0.58" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding DataContext.TargetYokaiList, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                              SelectedValue="{Binding EvolveParam, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="ParamHash"
                                              DisplayMemberPath="DisplayName"
                                              TextSearch.TextPath="DisplayName"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"
                                              Style="{StaticResource IosFilterComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Level Req" FontSize="11" FontWeight="Bold" Opacity="0.58" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EvolveLevel, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"
                                             HorizontalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Cost" FontSize="11" FontWeight="Bold" Opacity="0.58" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding EvolveCost, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"
                                             HorizontalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
