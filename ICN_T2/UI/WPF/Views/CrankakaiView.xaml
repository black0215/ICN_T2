<UserControl x:Class="ICN_T2.UI.WPF.Views.CrankakaiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:ICN_T2.UI.WPF.Converters"
             xmlns:viewmodels="clr-namespace:ICN_T2.UI.WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:CrankakaiViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1180"
             ClipToBounds="False"
             Background="Transparent"
             TextElement.Foreground="#1F1F1F"
             TextElement.FontFamily="{DynamicResource GmarketSansMedium}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/PuniPuniTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True"
          ClipToBounds="False"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          TextOptions.TextHintingMode="Fixed">

        <Grid Visibility="{Binding IsYW2Mode, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="70*"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="CharacterListHost" Grid.Column="0" Margin="0,90,0,0">
                <Border x:Name="CharacterListBackdropBorder" CornerRadius="24"
                        Tag="ToolPanelBackdropGlass"
                        IsHitTestVisible="False"/>
                <Border x:Name="PART_SearchPanel" Background="#33FFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="메달 / 확률 그룹"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1F1F1F"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding MedalGroups.Count, StringFormat='총 {0}개 그룹'}"
                                       FontSize="12"
                                       Opacity="0.65"/>
                        </StackPanel>

                        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                            <RadioButton Content="전체"
                                         IsChecked="{Binding IsFilterAll, Mode=TwoWay}"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton Content="실사용"
                                         IsChecked="{Binding IsFilterReachable, Mode=TwoWay}"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton Content="미사용"
                                         IsChecked="{Binding IsFilterUnreachable, Mode=TwoWay}"
                                         VerticalAlignment="Center"/>
                        </WrapPanel>

                        <Border Grid.Row="2"
                                Margin="0,0,0,10"
                                Height="42"
                                Style="{StaticResource IosSearchFieldStyle}">
                            <Grid>
                                <TextBlock Text="검색 (Hash / 상태)"
                                           FontSize="13"
                                           Foreground="#601F1F1F"
                                           Margin="14,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TxtMedalSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="TxtMedalSearch"
                                         Padding="14,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Text="{Binding MedalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         Foreground="#1F1F1F"/>
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="3"
                                 ItemsSource="{Binding FilteredMedalGroups}"
                                 SelectedItem="{Binding SelectedMedalGroup, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource IosListItemStyle}">
                                    <Setter Property="Foreground" Value="#1F1F1F"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding SummaryLine}" FontSize="11" Opacity="0.68"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="CharacterDetailHost" Grid.Column="2"
                  Margin="0,-15,0,-30"
                  ClipToBounds="False"
                  Visibility="{Binding SelectedMedalGroup, Converter={StaticResource NullToVisibility}}">
                <Border x:Name="CharacterDetailBackdropBorder" CornerRadius="28"
                        Tag="ToolPanelBackdropGlass"
                        IsHitTestVisible="False"/>
                <Border x:Name="CharacterDetailMainBorder" Background="#33FFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="14">
                    <ScrollViewer x:Name="DetailScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0">
                        <StackPanel>
                            <Border Background="#40FFFFFF"
                                    BorderBrush="#15FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             Text="{Binding SelectedMedalGroup.DisplayName, Mode=OneWay}"
                                             FontSize="28"
                                             FontWeight="Bold"
                                             FontFamily="{StaticResource GmarketSansBold}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#1F1F1F"
                                             VerticalAlignment="Center"
                                             Margin="0,0,0,8"
                                             IsReadOnly="True"
                                             IsReadOnlyCaretVisible="False"/>
                                    <TextBox Grid.Row="1"
                                             Text="{Binding SelectedMedalGroup.CoinHash, StringFormat=0x{0:X8}, Mode=OneWay}"
                                             FontSize="12"
                                             FontFamily="Consolas"
                                             Foreground="#1F1F1F"
                                             Margin="0,0,0,2"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             IsReadOnly="True"
                                             IsReadOnlyCaretVisible="True"
                                             VerticalContentAlignment="Center"
                                             ToolTip="해시 복사 가능 (Ctrl+C)"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding SelectedMedalGroup.SummaryLine}"
                                               FontSize="12"
                                               Opacity="0.72"
                                               FontFamily="Consolas"
                                               Foreground="#1F1F1F"/>
                                    <Button Grid.Row="3"
                                            Content="변경사항 되돌리기"
                                            Command="{Binding RevertChangesCommand}"
                                            Style="{StaticResource PuniCancelButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="슬롯 목록"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SlotCards}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#40FFFFFF"
                                                BorderBrush="#15FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding SlotStatus}"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               Opacity="0.7"
                                                               HorizontalAlignment="Right"/>
                                                </DockPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.6*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="보상 (요괴/아이템)"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <ComboBox ItemsSource="{Binding DataContext.RewardOptions, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                  SelectedValuePath="Key"
                                                                  DisplayMemberPath="Name"
                                                                  SelectedValue="{Binding ItemOrYokaiHash, UpdateSourceTrigger=PropertyChanged}"
                                                                  TextSearch.TextPath="Name"
                                                                  IsEditable="True"
                                                                  IsTextSearchEnabled="True"
                                                                  IsEnabled="{Binding CanEditItemFields}"
                                                                  Style="{StaticResource IosFilterComboBoxStyle}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                        <TextBlock Text="CapsuleHash"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding CapsuleHashText}"
                                                                   FontFamily="Consolas"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                                        <TextBlock Text="가중치"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBox Text="{Binding RateWeightRaw, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding CanEditRateWeight}"
                                                                 FontFamily="Consolas"
                                                                 HorizontalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                                        <TextBlock Text="확률%"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding RatePercentText}"
                                                                   FontFamily="Consolas"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4" Margin="0,0,6,0">
                                                        <TextBlock Text="Unk1"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBox Text="{Binding Unk1, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding CanEditItemFields}"
                                                                 FontFamily="Consolas"
                                                                 HorizontalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="5" Margin="0,0,6,0">
                                                        <TextBlock Text="Unk2"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBox Text="{Binding Unk2, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding CanEditItemFields}"
                                                                 FontFamily="Consolas"
                                                                 HorizontalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="6" Margin="0,0,6,0">
                                                        <TextBlock Text="Unk3"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBox Text="{Binding Unk3, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding CanEditItemFields}"
                                                                 FontFamily="Consolas"
                                                                 HorizontalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="7">
                                                        <TextBlock Text="Unk4"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.58"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBox Text="{Binding Unk4, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding CanEditItemFields}"
                                                                 FontFamily="Consolas"
                                                                 HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="머신 라우트 (이 그룹 참조)"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Margin="0,10,0,8"/>

                            <ItemsControl ItemsSource="{Binding SelectedMachineRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#40FFFFFF"
                                                BorderBrush="#15FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="10"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding MachineHash, StringFormat='MachineHash: 0x{0:X8}'}"
                                                               FontFamily="Consolas"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding RouteHash, StringFormat='RouteHash: 0x{0:X8}'}"
                                                               FontFamily="Consolas"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding CoinHash, StringFormat='CoinHash(v3): 0x{0:X8}'}"
                                                               FontFamily="Consolas"
                                                               FontSize="12"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                    <TextBlock Text="RouteMode(v2)"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Opacity="0.58"
                                                               Margin="0,0,0,6"/>
                                                    <TextBox Text="{Binding RouteMode, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas"
                                                             HorizontalContentAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Unk4(v4)"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Opacity="0.58"
                                                               Margin="0,0,0,6"/>
                                                    <TextBox Text="{Binding Unk4, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas"
                                                             HorizontalContentAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Visibility="{Binding IsNotYW2Mode, Converter={StaticResource BoolToVisibility}}"
                CornerRadius="20"
                Background="#22FFFFFF"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                Padding="22"
                Margin="0,80,0,30">
            <StackPanel>
                <TextBlock Text="{Binding UnsupportedMessage}"
                           FontSize="13"
                           Opacity="0.8"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
